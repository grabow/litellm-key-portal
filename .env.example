# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=your-master-key

# SMTP (Hochschule) – leer lassen wenn Gmail verwendet wird
SMTP_HOST=smtp.hs-offenburg.de
SMTP_PORT=587
SMTP_USER=portal-noreply@hs-offenburg.de
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=LiteLLM Key Portal <portal-noreply@hs-offenburg.de>

# Gmail (optional) – App-Key aus Google-Konto → Sicherheit → App-Passwörter
# Wenn gesetzt, wird Gmail statt SMTP verwendet
GMAIL_USER=your-address@gmail.com
GMAIL_APP_KEY=xxxx-xxxx-xxxx-xxxx

# Verifikationscode
CODE_SECRET=change-me-to-random-32-char-secret

# Zugangsbeschränkung
ALLOWED_DOMAIN=hs-offenburg.de

# Budgets (€/Monat)
STUDENT_BUDGET=5.00
PROFESSOR_BUDGET=20.00
ADMIN_BUDGET=50.00

# Rate Limiting
RATE_LIMIT_REQUEST_CODE=5/minute
RATE_LIMIT_VERIFY=10/minute
CODE_COOLDOWN_MINUTES=5

# Portal-Datenbank
DATABASE_URL=postgresql://portal:portal@localhost:5433/portal

# Admin-Bereich (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Empfängeradresse für Test-Info-Mail im Admin-Bereich und per CLI
TEST_INFO_EMAIL=test@hs-offenburg.de

# Debug-Logging (true/false) → schreibt in logging.txt
DEBUG=false
