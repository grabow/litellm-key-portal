# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=your-master-key

# SMTP (leave empty if Gmail is used)
SMTP_HOST=smtp.hs-offenburg.de
SMTP_PORT=587
SMTP_USER=portal-noreply@hs-offenburg.de
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=LiteLLM Key Portal <portal-noreply@hs-offenburg.de>

# Gmail (optional) – app password from your Google account
# If set, Gmail is used instead of SMTP
GMAIL_USER=your-address@gmail.com
GMAIL_APP_KEY=xxxx-xxxx-xxxx-xxxx

# Verification code
CODE_SECRET=change-me-to-random-32-char-secret

# Access restriction
ALLOWED_DOMAIN=hs-offenburg.de

# Budgets (€/month)
STUDENT_BUDGET=5.00
PROFESSOR_BUDGET=20.00
ADMIN_BUDGET=50.00

# Rate Limiting
RATE_LIMIT_REQUEST_CODE=5/minute
RATE_LIMIT_VERIFY=10/minute
CODE_COOLDOWN_MINUTES=5

# Portal database
DATABASE_URL=postgresql://portal:portal@localhost:5433/portal

# Admin area (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Recipient address for the test info mail in the admin UI and via CLI
# The info mail content is loaded from infomail.txt.
TEST_INFO_EMAIL=test@hs-offenburg.de

# Debug logging (true/false) -> writes to logging.txt
DEBUG=false
